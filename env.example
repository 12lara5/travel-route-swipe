# Copy this file to .env and fill in your own keys
# Never commit .env — it's in .gitignore

# Google Places API (New)
# Get it: console.cloud.google.com → Enable "Places API (New)" → Create API Key
GOOGLE_PLACES_KEY=

# OpenRouteService (for walking route lines)
# Get it free: openrouteservice.org → Dashboard → API Keys
VITE_ORS_KEY=

# Backend port (default 4001, no need to change locally)
PORT=4001

# Only needed if you use the database features
DATABASE_URL=

# Only needed when deploying — set to your Railway backend URL
# VITE_API_URL=https://your-app.up.railway.app
